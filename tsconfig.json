{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "commonjs",
  "noEmit": true,
    "target": "es2019",
    "moduleResolution": "node",
  "allowImportingTsExtensions": true,
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}