# Copie este arquivo para .env e preencha os valores.
# Em produção, estas variáveis são configuradas no painel do serviço de
# hospedagem (Render/Railway/etc), não neste arquivo.

JWT_SECRET=
PORT=3000

# Local dev: suba um Postgres com `docker compose up -d` e use a URL abaixo.
# Em produção, aponte para o seu banco real (ex: Neon) — o SSL é habilitado
# automaticamente quando a URL não é localhost.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/studiotrack

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=

# Opcional: sobrescreve as origens permitidas por CORS (separadas por vírgula).
# Se não definido, o servidor já libera a URL de produção e localhost:3000/3001.
# CORS_ORIGIN=https://studio-track.vercel.app,http://localhost:3001

# URL do frontend, usada pra montar os links de sucesso/cancelamento do Stripe Checkout
FRONTEND_URL=http://localhost:3001

# Email SMTP — usado para recuperacao de senha.
# Para Gmail, ative a verificacao em duas etapas e gere uma senha de app.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=app.studiotrack@gmail.com
MAIL_PASS=
MAIL_FROM="Studio Track <app.studiotrack@gmail.com>"

# Stripe — veja o Dashboard do Stripe (modo teste enquanto não for pra produção)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
